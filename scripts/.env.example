# SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY
# → 이 파일을 복사해서 scripts/.env 로 저장한 후 실제 값을 채우세요
# → .env 파일은 .gitignore에 의해 Git에 올라가지 않습니다

# ══════════════════════════════════════════════════════════
# Supabase (Settings > API 에서 확인)
# ══════════════════════════════════════════════════════════

# Project URL ←←← 반드시 필요!
# 위치: Supabase 대시보드 → 프로젝트 선택 → Settings → API → Project URL
# 형식: https://xxxxxxxxxxxxxxxxxxxx.supabase.co
SUPABASE_URL=https://xxxxxxxxxxxxxxxxxxxx.supabase.co

# 프론트엔드 공개 키 (Anon/Publishable 키)
SUPABASE_PUBLISHABLE_KEY=sb_publishable_B_2M0gs2vHlK8mYZn1XfnQ_JJSSTuWY

# 서버 전용 서비스 롤 키 (RLS 우회, 절대 노출 금지!)
SUPABASE_SERVICE_KEY=YOUR_SUPABASE_SERVICE_KEY

# 카카오 REST API 키 (developers.kakao.com > 내 애플리케이션 > 앱 키 > REST API 키)
KAKAO_REST_KEY=98fe39f22d89245260ffcf2f7dbb1bd5
kakao_javascript_key=3cd29c9d5d9313c116fa1f9048fba176

# 공공데이터포털 착한가격업소 API 키 (collect-public-data.js 용)
PUBLIC_DATA_API_KEY=abcdef%2BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA%3D%3D

# 행정안전부 LOCALDATA API 키 (check-closed-restaurants.js 용)
LOCALDATA_API_KEY=abcdef%2BxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxA%3D%3D
