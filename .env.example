# ============================================================
# 도시락탈출 - 환경변수 목록 (.env.example)
# 실제 사용 시 이 파일을 .env.local 로 복사 후 값을 채우세요.
# $ cp .env.example .env.local
# ============================================================

# ── Supabase ──────────────────────────────────────────────
# Supabase 프로젝트 설정 > API 에서 확인
VITE_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# Supabase Edge Functions / 서버사이드에서만 사용 (절대 클라이언트에 노출 금지)
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6...

# ── 카카오맵 API ──────────────────────────────────────────
# https://developers.kakao.com > 내 애플리케이션 > 앱 키 > JavaScript 키
VITE_KAKAO_MAP_KEY=abcdef1234567890abcdef1234567890

# ── Cloudflare Workers ────────────────────────────────────
# Cloudflare 대시보드 > Workers & Pages > 설정에서 확인
CF_ACCOUNT_ID=your_cloudflare_account_id
CF_API_TOKEN=your_cloudflare_api_token

# Workers KV 네임스페이스 ID (geohash 캐시 저장소)
CF_KV_GEO_CACHE_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── 공공데이터 API ────────────────────────────────────────
# https://www.data.go.kr > 마이페이지 > 인증키
PUBLIC_DATA_API_KEY=your_public_data_portal_api_key

# ── GitHub Actions (CI/CD) ────────────────────────────────
# GitHub 저장소 > Settings > Secrets and variables > Actions 에 등록
# CF_PAGES_PROJECT_NAME=dosirak-escape
# (위 값들을 모두 GitHub Secrets 에 동일하게 등록하면 됨)

# ── 앱 설정 ───────────────────────────────────────────────
# 광고 반경 기본값 (미터)
VITE_AD_RADIUS_METERS=1000

# 점심 타임세일 시간대 (24h 기준)
VITE_LUNCH_START_HOUR=11
VITE_LUNCH_END_HOUR=13

# 상단 고정 광고 슬롯 수 (최대 3)
VITE_PINNED_AD_SLOTS=3

# ── 토스페이먼츠 ──────────────────────────────────────────
# https://developers.tosspayments.com > 내 개발정보
VITE_TOSS_CLIENT_KEY=test_ck_xxxxxxxxxxxxxxxxxxxx
TOSS_SECRET_KEY=test_sk_xxxxxxxxxxxxxxxxxxxx    # 서버사이드 전용 (절대 클라이언트 노출 금지)

# ── 카카오 REST API (지오코딩: 주소→좌표 변환) ────────────
# developers.kakao.com > 내 애플리케이션 > 앱 키 > REST API 키
VITE_KAKAO_REST_KEY=abcdef1234567890abcdef1234567890

# ── Cloudflare R2 (원본 로그 저장, 무료 10GB/월) ──────────
# 버킷 생성: npx wrangler r2 bucket create dosirak-logs
# Workers secret으로 등록: npx wrangler secret put R2_BUCKET_NAME
R2_BUCKET_NAME=dosirak-logs
